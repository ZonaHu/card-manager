# Server Configuration
PORT=3001

# Frontend URL - used for CORS and OAuth redirects. REQUIRED for non-local deployments.
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed origins for CORS. Defaults to FRONTEND_URL.
# ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com

# JWT Authentication - REQUIRED. Server refuses to start without this.
# Generate a strong random string (e.g., openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret - REQUIRED. Server refuses to start without this.
# Generate a strong random string (e.g., openssl rand -base64 32)
SESSION_SECRET=your-session-secret-change-this-in-production

# Column-level encryption key for Plaid access tokens - REQUIRED.
# Generate with: openssl rand -hex 32
# IMPORTANT: Rotating this key will invalidate all existing Plaid connections
# (users will need to reconnect their accounts).
ENCRYPTION_KEY=generate-a-64-char-hex-string-with-openssl-rand-hex-32

# Plaid Configuration
# Get your credentials from https://dashboard.plaid.com/
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret-key
# Options: sandbox, development, production
PLAID_ENV=sandbox

# Google OAuth Configuration (Optional)
# Get your credentials from https://console.cloud.google.com/
# If not using Google OAuth, you can leave these empty or remove them
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-secret

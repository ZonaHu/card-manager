# Server Configuration
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
SESSION_SECRET=your-session-secret-here-change-this-too

# Plaid Configuration
# Get these from https://dashboard.plaid.com/
PLAID_CLIENT_ID=your-plaid-client-id-here
PLAID_SECRET=your-plaid-secret-key-here
PLAID_ENV=sandbox
# PLAID_ENV options:
# - sandbox: For development/testing (fake data)
# - development: For testing with real banks (limited institutions)
# - production: For live deployment

# Google OAuth Configuration (Optional)
# Get these from https://console.cloud.google.com/
# Create OAuth 2.0 credentials and set redirect URI to:
# http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
GOOGLE_CLIENT_SECRET=your-google-oauth-secret-here

# Debug Mode (Optional)
# DEBUG=true